# Install as /etc/hako-creative/telegram.env
# Owner: root:hako-creative, mode 0640

TELEGRAM_BOT_TOKEN=REPLACE_WITH_NEW_HAKO_BOT_TOKEN
TELEGRAM_BOT_IDENTITY=hako_receiver
TELEGRAM_ALLOWED_USER_IDS=REPLACE_WITH_NUMERIC_USER_IDS
TELEGRAM_ALLOWED_BOT_IDS=REPLACE_WITH_NUMERIC_HERMES_BOT_ID
TELEGRAM_MAX_BOT_DEPTH=4
TELEGRAM_MAX_MESSAGES_PER_MINUTE=20
TELEGRAM_ACK_HUMANS=1
HAKO_CONTROL_HMAC_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES

# This token belongs only to the new HAKO receiver bot.
# Do not copy the existing Hermes bot token into this file.
