# Install as /etc/hako-creative/runtime.env
# Owner: root:hako-creative, mode 0640

DATABASE_URL=postgresql://hako_creative:REPLACE_ME@127.0.0.1:5432/hako_creative_v0
HAKO_PROJECT=hako-creative
HAKO_PORT=8099
HAKO_STORAGE_ROOT=/srv/hako-creative/assets
PYTHONUNBUFFERED=1

# No Telegram token, model key or Hermes credential belongs in this file.
